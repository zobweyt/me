---
import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";
import { cx } from "class-variance-authority";
import { getTranslator } from "@/i18n";
import ProjectCardStars from "./ProjectCardStars.astro";
import ProjectCardStarsSkeleton from "./ProjectCardStarsSkeleton.astro";

type Props = {
  entry: CollectionEntry<"projects">;
};

const { entry } = Astro.props;

const formatter = new Intl.DateTimeFormat(Astro.currentLocale, {
  year: "numeric",
  month: "short",
});

const cardClass = cx([
  "relative cursor-pointer rounded-xl p-4 flex flex-col outline-none",
  "transition duration-300 ease-in-out",
  "bg-[var(--project-card-color)]/5 dark:bg-[var(--project-card-color)]/10 hover:bg-[var(--project-card-color)]/15 active:ring-[var(--project-card-color)]/30 focus-visible:bg-[var(--project-card-color)]/15 active:ring-[var(--project-card-color)]/30",
  "ring ring-[var(--project-card-color)]/15 ring-inset hover:ring-[var(--project-card-color)]/30 focus-visible:ring-[var(--project-card-color)]/30 active:hover:ring-[var(--project-card-color)]/50",
]);

const cardStyle = { "--project-card-color": entry.data.color };

const t = getTranslator(Astro.currentLocale);
---

<a
  href={entry.data.href}
  target="_blank"
  rel="noopener noreferrer"
  class={cardClass}
  style={cardStyle}
  aria-label={entry.data.title}
>
  <div class="mb-1 flex items-center gap-2">
    <Image
      src={entry.data.logo}
      alt={entry.data.title}
      width={24}
      height={24}
      class={cx("shadow-xs", entry.data.logoShape === "circle" && "rounded-full")}
      loading="eager"
      draggable="false"
    />
    <span class="text-xl leading-normal font-semibold">
      {entry.data.title}
    </span>
  </div>
  <p class="font-serif text-current/85 mb-2 text-pretty">
    {entry.data.description}
  </p>
  <ProjectCardStars project={entry.data} server:defer>
    <ProjectCardStarsSkeleton slot="fallback" />
  </ProjectCardStars>
  <p
    class="first-letter:uppercase absolute right-3 top-3 font-mono text-sm text-[var(--project-card-color)]"
  >
    {entry.data.dateEnd
        ? formatter.formatRange(entry.data.dateStart, entry.data.dateEnd)
        : `${formatter.format(entry.data.dateStart)} – ${t("now")}`}
  </p>
</a>
