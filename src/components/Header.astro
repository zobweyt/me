---
import Container from "@/components/Container.astro";
import Link from "@/components/Link.astro";
import { getBlogEntries, getProjectsEntries } from "@/content/entries";
import { getTranslator } from "@/i18n";

import Search from "./Search";

const t = getTranslator(Astro.currentLocale);
const posts = await getBlogEntries({ locale: Astro.currentLocale });
const projects = await getProjectsEntries({ locale: Astro.currentLocale });
---

<header class="sticky top-0 isolate z-20 bg-body py-4 sm:py-6">
  <Container>
    <div class="flex flex-wrap items-center justify-between gap-y-2">
      <Link
        href={`/${Astro.currentLocale}`}
        underline={false}
        class="font-semibold text-current/75"
        color="light-dark(#000, #fff)"
      >
        {t("name")}
      </Link>

      <Search
        client:idle
        posts={posts}
        projects={projects}
        url={Astro.url}
        site={Astro.site}
        currentLocale={Astro.currentLocale}
      />
    </div>
  </Container>
</header>
