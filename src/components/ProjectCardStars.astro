---
import type { InferEntrySchema } from "astro:content";
import { getProjectStars } from "@/content/stars";

type Props = {
  project: InferEntrySchema<"projects">;
};

const { project, ...props } = Astro.props;

const stars = await getProjectStars(project);
---

{stars !== null && (
    <p class="flex items-center font-medium gap-1 font-mono text-sm text-[var(--project-card-color)]" {...props}>
      <span class="i-lucide:star text-base" />
      <span class="tabular-nums leading-none -mb-0.5">
        {stars}
      </span>
    </p>
  )}
