---
import { tv } from "tailwind-variants";

const styles = tv({
  base: [
    "article__content",
    "prose max-w-full prose-stone dark:prose-invert",
    "prose-p:text-justify prose-p:font-serif",
    "prose-inline-code:before:hidden prose-inline-code:after:hidden",
    "prose-inline-code:rounded-md prose-inline-code:bg-body-alt",
    "prose-inline-code:px-1 prose-inline-code:py-0.5",
    "prose-inline-code:ring prose-inline-code:ring-foreground/15",
    "prose-li:text-justify prose-li:font-serif",
    "prose-img:m-auto",
  ],
});
---

<article class={styles()}>
  <slot />
</article>
