---
import type { HTMLTag } from "astro/types";
import { cx } from "class-variance-authority";

export interface Props {
  as?: HTMLTag;
}

const { as: Element = "div", class: className, ...props } = Astro.props;
---

<Element
  class={cx([
    "prose max-w-full prose-neutral dark:prose-invert",
    "prose-p:text-justify prose-p:font-serif",
    "prose-code:before:hidden prose-code:after:hidden",
    "prose-code:rounded-md prose-code:bg-surface",
    "prose-code:px-1 prose-code:py-0.5",
    "prose-code:ring prose-code:ring-foreground/15",
    "prose-li:text-justify prose-li:font-serif",
    "prose-img:m-auto",
    className
  ])}
  {...props}
>
  <slot />
</Element>
