---
import type { HTMLTag } from "astro/types";
import { cx } from "class-variance-authority";

export interface Props {
  as?: HTMLTag;
}

const { as: Element = "div", class: className, ...props } = Astro.props;
---

<Element
  class={cx([
    "prose prose-zinc dark:prose-invert",
    "prose-code:(font-normal bg-surface text-foreground rounded-md px-1 py-0.5 before:hidden after:hidden)",
    "prose-headings:(first:mt-0 font-serif)",
    "prose-h2:scroll-mt-28! prose-h2:2xl:scroll-mt-20!",
    "prose-h3:scroll-mt-28! prose-h3:2xl:scroll-mt-18!",
    "prose-h4:scroll-mt-28! prose-h4:2xl:scroll-mt-16!",
    "prose-h5:scroll-mt-26! prose-h5:2xl:scroll-mt-14!",
    "prose-h6:scroll-mt-26! prose-h6:2xl:scroll-mt-14!",
    "prose-hr:border-foreground/5",
    className
  ])}
  {...props}
>
  <slot />
</Element>
