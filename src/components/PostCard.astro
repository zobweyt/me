---
import type { CollectionEntry } from "astro:content";
import { cx } from "class-variance-authority";
import PostTags from "./PostTags.astro";
import Time from "./Time.astro";

type Props = {
  entry: CollectionEntry<"blog">;
};

const { entry } = Astro.props;
---

<div class={cx([
      "group relative flex flex-nowrap items-center rounded-lg border border-foreground/15 p-4 hover:bg-foreground/5",
      "transition-colors duration-300 ease-in-out",
    ])}>
  <div class={"flex grow flex-col flex-nowrap"}>
    <a
      href={`/${Astro.currentLocale}/${entry.collection}/${entry.id.replace(`${Astro.currentLocale}/`, "")}`}
      class={"text-xl leading-normal font-semibold after:absolute after:inset-0 after:z-10"}
    >
      {entry.data.title}
    </a>

    <p class={"mt-1 mb-2 font-mono text-sm opacity-75 first-letter:uppercase"}>
      <Time date={entry.data.date} />
    </p>

    {entry.data.tags && <PostTags tags={entry.data.tags} />}
  </div>

  <span class={"i-material-symbols:arrow-right-alt-rounded text-2xl opacity-75 transition-opacity duration-300 ease-in-out group-hover:opacity-100"}/>
</div>
