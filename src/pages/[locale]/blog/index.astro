---
import { PostCard } from "@/components/collections/blog";
import { Section } from "@/components/site";
import { Link } from "@/components/ui";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getBlogPostsByYears } from "@/lib/collections/blog";
import { LOCALES, getTranslator } from "@/lib/i18n";

export const prerender = true;

export async function getStaticPaths() {
  return LOCALES.map((locale) => ({ params: { locale } }));
}

const t = getTranslator(Astro.currentLocale);

const { posts, years } = await getBlogPostsByYears({
  locale: Astro.currentLocale,
});
---

<BaseLayout title={t("blog.title")} description={t("blog.description")}>
  <Section class="sm:py-8 py-4 px-4 lg:px-8" pattern="grid">
    <Link
      href={`/${Astro.currentLocale}`}
      class="text-base flex items-center justify-center gap-1 me-auto mb-5"
      underline={false}
    >
      <span class="i-f7:chevron-left text-2xl" />
      <span transition:name="home-page-title">{t("home.title")}</span>
    </Link>
    <div class="flex justify-between items-center mb-3">
      <h1
        class="text-3xl font-(serif semibold)"
        transition:name="blog-page-title"
      >
        {t("blog.title")}
      </h1>
      <a
        href={`${Astro.site}${Astro.currentLocale}/rss.xml`}
        class="flex w-fit cursor-pointer select-none items-center justify-center gap-1 rounded-full border bg-surface/50 px-2.5 py-1.5 text-sm leading-none border-[#FF6600]/25 motion-safe:transition @hover:bg-surface focus-visible:(outline-3 outline-offset-2 outline-selection bg-surface) text-[#FF6600] active:(translate-y-px scale-[0.99] bg-surface)"
      >
        <span class="i-lucide:rss text-lg" />
        RSS
      </a>
    </div>
    <p class="text-(pretty current/75)">{t("blog.description")}</p>
  </Section>
  <Section class="sm:py-8 py-4 px-4 lg:px-8">
    <div class="space-y-4">
      {years.map((year) => (
        <section>
          <h2 class="mb-2 text-xl font-(serif medium)">{year}</h2>
          <div>
            <ul class="flex flex-col gap-4">
              {posts[year].map((post) => (
                <li>
                  <PostCard post={post} />
                </li>
              ))}
            </ul>
          </div>
        </section>
      ))}
    </div>
  </Section>
</BaseLayout>
