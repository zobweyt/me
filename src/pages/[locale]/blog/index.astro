---
import { PostCard } from "@/components/collections/blog";
import { Section } from "@/components/site";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getBlogPostsByYears } from "@/lib/collections/blog";
import { LOCALES, getTranslator } from "@/lib/i18n";

export const prerender = true;

export async function getStaticPaths() {
  return LOCALES.map((locale) => ({ params: { locale } }));
}

const t = getTranslator(Astro.currentLocale);

const { posts, years } = await getBlogPostsByYears({
  locale: Astro.currentLocale,
});
---

<BaseLayout title={t("blog.title")} description={t("blog.description")}>
  <Section pattern="grid">
    <div class="flex justify-between items-center mb-3">
      <h1
        class="text-3xl font-(serif semibold)"
        transition:name="blog-page-title"
      >
        {t("blog.title")}
      </h1>
      <a
        href={`${Astro.site}${Astro.currentLocale}/rss.xml`}
        class="flex w-fit cursor-pointer items-center justify-center gap-1 rounded-full border bg-surface/50 px-2.5 py-1.5 text-sm leading-none border-[#FF6600]/25 motion-safe:transition outline-none active:bg-surface @hover:bg-surface focus-visible:bg-surface text-[#FF6600]"
      >
        <span class="i-lucide:rss text-lg" />
        RSS
      </a>
    </div>
    <p class="text-(pretty current/75)">{t("blog.description")}</p>
  </Section>

  <Section>
    <div class="space-y-4">
      {years.map((year) => (
        <section>
          <div class="py-2 text-lg font-semibold">{year}</div>
          <div>
            <ul class="flex flex-col gap-4">
              {posts[year].map((post) => (
                <li>
                  <PostCard post={post} />
                </li>
              ))}
            </ul>
          </div>
        </section>
      ))}
    </div>
  </Section>
</BaseLayout>
