---
import { render } from "astro:content";
import { PostTags } from "@/components/collections/blog";
import { components } from "@/components/mdx";
import { Section, Toc } from "@/components/site";
import { Article, Link, Prose, Time } from "@/components/ui";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { type BlogPost, getBlogPosts } from "@/lib/collections/blog";
import { getTranslator } from "@/lib/i18n";

export const prerender = true;

export async function getStaticPaths() {
  const posts = await getBlogPosts();

  return posts.map((post) => {
    const [locale, id] = post.id.split("/");

    return {
      params: { locale, id },
      props: { post },
    };
  });
}

interface Props {
  post: BlogPost;
}

const { post } = Astro.props;
const t = getTranslator(Astro.currentLocale);
const { Content, headings } = await render(post);
---

<meta property="article:author" content={t("name")}>
<meta property="article:published_time" content={post.data.date.toISOString()}>

<BaseLayout title={post.data.title} description={post.data.description}>
  <Section class="sm:py-8 py-4 px-4 lg:px-8" pattern="grid">
    <nav class="flex justify-between items-center mb-6">
      <Link
        href={`/${Astro.currentLocale}/blog`}
        className="text-base flex items-center justify-center gap-1"
        underline={false}
      >
        <span class="i-f7:chevron-left text-2xl" />
        <span transition:name="blog-page-title">{t("blog.title")}</span>
      </Link>
      <!-- <Link
        href={`${Astro.url.pathname.replace(/\/+$/, "")}.md`}
        class="text-sm flex items-center @hover:bg-surface/75 focus-visible:bg-surface/75 px-1.5 py-0.5 rounded-sm active:bg-surface! justify-center gap-1.5"
        underline={false}
      >
        <span class="i-simple-icons:markdown text-xl" />
        <span>{t("view.markdown")}</span>
      </Link> -->
    </nav>

    <Prose>
      <h1 class="mb-4" transition:name={`post-${post.id}-title`}>
        {post.data.title}
      </h1>

      <p
        class="mt-3 mb-4 text-lg text-current/80 text-pretty"
        transition:name={`post-${post.id}-description`}
      >
        {post.data.description}
      </p>

      <p
        class="font-base text-current/60 font-mono text-sm first-letter:uppercase mb-2"
      >
        <Time date={post.data.date} transition:name={`post-${post.id}-date`} />
      </p>

      {post.data.tags && <PostTags tags={post.data.tags} transitionId={`post-${post.id}-tags`} />}
    </Prose>
  </Section>
  <Section class="sm:py-8 py-4 px-4 lg:px-8">
    {!!headings.length && (
      <Toc headings={headings} translations={{toc: t("toc")}} variant="mobile" client:load />
    )}

    <Article><Content components={components} /></Article>

    {!!headings.length && (
      <Toc headings={headings} translations={{toc: t("toc")}} variant="desktop" slot="right" client:load />
    )}
  </Section>
</BaseLayout>
