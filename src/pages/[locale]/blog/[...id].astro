---
import { render } from "astro:content";
import Article from "@/components/Article.astro";
import Link from "@/components/Link.astro";
import { components } from "@/components/mdx";
import PostTags from "@/components/PostTags.astro";
import Prose from "@/components/Prose.astro";
import Time from "@/components/Time.astro";
import PageLayout from "@/layouts/PageLayout.astro";
import { type BlogPost, getBlogPosts } from "@/lib/collections";
import { getTranslator } from "@/lib/i18n";

const t = getTranslator(Astro.currentLocale);

export const prerender = true;

export async function getStaticPaths() {
  const posts = await getBlogPosts();

  return posts.map((post) => {
    const locale = post.id.split("/")[0];
    const id = `${post.id.replace(`${locale}/`, "")}`;

    return {
      params: { locale, id },
      props: post,
    };
  });
}

type Props = BlogPost;

const post = Astro.props;
const { Content } = await render(post);
---

<PageLayout
  title={post.data.title}
  description={post.data.description}
  publishedAt={post.data.date}
>
  <Link
    href={`/${Astro.currentLocale}/blog`}
    underline={false}
    active={false}
    class="mb-6 text-base flex items-center justify-center gap-1"
  >
    <span class="i-f7:chevron-left text-2xl" />
    <span transition:name="blog-page-title"> {t("blog.title")} </span>
  </Link>

  <Prose>
    <hgroup>
      <h1 class="mb-3" transition:name={`post-${post.id}-title`}>
        {post.data.title}
      </h1>
      <p
        class="mt-3 mb-4 text-lg text-pretty"
        transition:name={`post-${post.id}-description`}
      >
        {post.data.description}
      </p>
    </hgroup>

    <p class="font-base first-letter:uppercase mb-2">
      <Time date={post.data.date} transition:name={`post-${post.id}-date`} />
    </p>

    {post.data.tags && <PostTags tags={post.data.tags} transitionId={`post-${post.id}-tags`} />}

    <hr class="border-dashed">
  </Prose>

  <Article><Content components={components} /></Article>
</PageLayout>
