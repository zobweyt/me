---
import { ProjectCard } from "@/components/collections/projects";
import { Section, Toc } from "@/components/site";
import { Link } from "@/components/ui";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getProjectsWithStatsByYears } from "@/lib/collections/projects";
import { getTranslator } from "@/lib/i18n";

export const prerender = false;

Astro.response.headers.set(
  "Cache-Control",
  "public, s-maxage=3600, stale-while-revalidate=60",
);

const t = getTranslator(Astro.currentLocale);

const { projects, years } = await getProjectsWithStatsByYears({
  locale: Astro.currentLocale,
});

const headings = years.map((year) => ({ text: year, slug: year, depth: 2 }));
---

<BaseLayout title={t("projects.title")} description={t("projects.description")}>
  <Section class="sm:py-8 py-4 px-4 lg:px-8" pattern="grid">
    <Link
      href={`/${Astro.currentLocale}`}
      className="text-base flex items-center justify-center gap-1 me-auto mb-5"
      underline={false}
    >
      <span class="i-f7:chevron-left text-2xl" />
      <span transition:name="home-page-title">{t("home.title")}</span>
    </Link>
    <h1 class="mb-3 text-3xl font-(serif semibold)">{t("projects.title")}</h1>
    <p class="text-(pretty current/75)">{t("projects.description")}</p>
  </Section>
  <Section class="space-y-4 sm:py-8 py-4 px-4 lg:px-8">
    {!!headings.length && (
      <Toc headings={headings} translations={{toc: t("toc")}} variant="mobile" client:load />
    )}

    {years.map((year) => (
      <section>
        <h2 class="mb-2 text-xl font-(serif medium) scroll-mt-28! 2xl:scroll-mt-18!" id={year}>{year}</h2>
        <div>
          <ul class="flex flex-col gap-4">
            {projects[year].map((project) => (
              <li>
                <ProjectCard project={project} />
              </li>
            ))}
          </ul>
        </div>
      </section>
    ))}

    {!!headings.length && (
      <Toc headings={headings} translations={{toc: t("toc")}} variant="desktop" slot="right" client:load />
    )}
  </Section>
</BaseLayout>
