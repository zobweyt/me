---
import { ProjectCard } from "@/components/collections/projects";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getProjectsWithStatsByYears } from "@/lib/collections/projects/content";
import { getTranslator } from "@/lib/i18n";

export const prerender = false;

Astro.response.headers.set(
  "Cache-Control",
  "public, s-maxage=3600, stale-while-revalidate=60",
);

const t = getTranslator(Astro.currentLocale);

const { projects, years } = await getProjectsWithStatsByYears({
  locale: Astro.currentLocale,
});
---

<BaseLayout title={t("projects.title")} description={t("projects.description")}>
  <div class="space-y-10">
    <hgroup>
      <h1 class="mb-3 text-3xl font-semibold">{t("projects.title")}</h1>
      <p class="font-serif text-pretty">{t("projects.description")}</p>
    </hgroup>

    <div class="space-y-4">
      {years.map((year) => (
        <section>
          <div class="sticky top-12 z-10 bg-body py-2 text-lg font-semibold sm:top-16">{year}</div>
          <div>
            <ul class="flex flex-col gap-4">
              {projects[year].map((project) => (
                <li>
                  <ProjectCard entry={project} />
                </li>
              ))}
            </ul>
          </div>
        </section>
      ))}
    </div>
  </div>
</BaseLayout>
