---
import {
  CONTENT_RECENT_BLOG_POSTS_COUNT,
  CONTENT_RECENT_PROJECTS_COUNT,
} from "astro:env/server";
import { cx } from "class-variance-authority";
import { PostCard } from "@/components/collections/blog";
import { ProjectCard } from "@/components/collections/projects";
import { Skills } from "@/components/collections/skills";
import { Section } from "@/components/site";
import { Link } from "@/components/ui";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getBlogPosts } from "@/lib/collections/blog";
import { getProjectsWithStats } from "@/lib/collections/projects";
import { getSkills } from "@/lib/collections/skills";
import { getTranslator } from "@/lib/i18n";

export const prerender = false;

Astro.response.headers.set(
  "Cache-Control",
  "public, s-maxage=3600, stale-while-revalidate=60",
);

const t = getTranslator(Astro.currentLocale);

const blog = await getBlogPosts({
  count: CONTENT_RECENT_BLOG_POSTS_COUNT,
  locale: Astro.currentLocale,
});

const projects = await getProjectsWithStats({
  count: CONTENT_RECENT_PROJECTS_COUNT,
  locale: Astro.currentLocale,
});

const skills = await getSkills();
---

<BaseLayout title={t("home.title")} description={t("home.description")}>
  <Section pattern="grid">
    <h1 class="mb-3 text-3xl font-semibold font-serif">{t("home.title")}</h1>
    <p class="text-pretty">{t("home.description")}</p>
  </Section>

  <Section>
    <h2 class="text-xl font-semibold font-serif mb-1">{t("skills.title")}</h2>
    <Skills client:idle skills={skills} locale={Astro.currentLocale} />
  </Section>

  <Section class="space-y-2">
    <div class="flex flex-wrap items-center justify-between gap-2">
      <h2 class="text-xl font-semibold font-serif">{t("projects.recent")}</h2>
      <Link href={`/${Astro.currentLocale}/projects`}>
        {t("projects.all")}
      </Link>
    </div>
    <ul
      class={cx("grid gap-4", projects.length > 1 ? "sm:grid-cols-2" : "sm:grid-cols-1")}
    >
      {projects.map((entry) => (
          <li>
            <ProjectCard entry={entry} />
          </li>
        ))}
    </ul>
  </Section>

  <Section class="space-y-2">
    <div class="flex flex-wrap items-center justify-between gap-2">
      <h2 class="text-xl font-semibold font-serif">{t("blog.latest")}</h2>
      <Link href={`/${Astro.currentLocale}/blog`}>{t("blog.all")}</Link>
    </div>
    <ul class="space-y-4">
      {blog.map((entry) => (
          <li>
            <PostCard entry={entry} />
          </li>
        ))}
    </ul>
  </Section>
</BaseLayout>
